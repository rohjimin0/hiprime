# Neon PostgreSQL (https://neon.tech 에서 생성)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_URL=https://hiprime.vercel.app
NEXTAUTH_SECRET=여기에_랜덤_비밀키_입력  # openssl rand -base64 32

# 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=변경하세요

# Vercel Blob (Vercel 대시보드 > Storage > Blob 에서 생성)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
